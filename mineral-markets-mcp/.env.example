# =============================================================================
# mineral-markets-mcp — configuración de entorno
# Copia este archivo a ".env" y rellena solo lo que tengas licenciado.
# Cualquier variable que dejes vacía hace que ese conector se reporte como
# "not_configured" en health_check() — el servidor sigue funcionando con el
# conector "open" (yfinance + Stooq, sin credenciales).
# =============================================================================

# ---- Configuración global ---------------------------------------------------
LOG_LEVEL=INFO
HTTP_TIMEOUT_SECONDS=15
CACHE_TTL_SECONDS=30
RATE_LIMIT_PER_SECOND=5
RETRY_MAX_ATTEMPTS=3

# ---- FactSet -----------------------------------------------------------------
# API: FactSet Developer Portal (Prices & Fundamentals API), OAuth2 client credentials.
# Docs: https://developer.factset.com/api-catalog
FACTSET_CLIENT_ID=
FACTSET_CLIENT_SECRET=
FACTSET_BASE_URL=https://api.factset.com

# ---- S&P Global Market Intelligence (Capital IQ Pro API) ---------------------
# API: Capital IQ Pro API (REST), API key + secret emitidos por S&P Global.
# Docs: https://www.capitaliq.spglobal.com/apidocs/ciqpro/
SP_GLOBAL_API_KEY=
SP_GLOBAL_API_SECRET=
SP_GLOBAL_BASE_URL=https://api-ciq.marketintelligence.spglobal.com

# ---- LSEG Data Platform (ex-Refinitiv Data Library) ---------------------------
# API: LSEG/Refinitiv Data Platform (RDP), auth por App Key + credenciales de máquina.
# Docs: https://developers.lseg.com/en/api-catalog/refinitiv-data-platform
LSEG_APP_KEY=
LSEG_RDP_LOGIN=
LSEG_RDP_PASSWORD=
LSEG_BASE_URL=https://api.refinitiv.com

# ---- MSCI (ESG & Index APIs) --------------------------------------------------
# API: MSCI ESG Manager API / MSCI Index API, OAuth2 client credentials.
# Docs: https://developer.msci.com/
MSCI_CLIENT_ID=
MSCI_CLIENT_SECRET=
MSCI_BASE_URL=https://api.msci.com

# ---- PitchBook (mercados privados) --------------------------------------------
# API: PitchBook API / Data Feed, API key.
# Docs: https://pitchbook.com/data/api (acceso vía tu account manager de PitchBook)
PITCHBOOK_API_KEY=
PITCHBOOK_BASE_URL=https://api.pitchbook.com

# ---- Morningstar Direct / Data APIs -------------------------------------------
# API: Morningstar Direct Web Services (DWS), OAuth2 client credentials.
# Docs: https://developer.morningstar.com/
MORNINGSTAR_CLIENT_ID=
MORNINGSTAR_CLIENT_SECRET=
MORNINGSTAR_BASE_URL=https://api.morningstar.com

# ---- Moody's Analytics / Ratings API ------------------------------------------
# API: Moody's API Marketplace (Ratings API), OAuth2 client credentials.
# Docs: https://developer.moodys.com/
MOODYS_CLIENT_ID=
MOODYS_CLIENT_SECRET=
MOODYS_BASE_URL=https://api.moodys.com

# ---- Aiera (transcripts & event intelligence) ---------------------------------
# API: Aiera API, bearer API key.
# Docs: https://aiera.com/platform/api/
AIERA_API_KEY=
AIERA_BASE_URL=https://api.aiera.com

# ---- Daloopa (fundamentals extraction) ----------------------------------------
# API: Daloopa API, bearer API key.
# Docs: https://www.daloopa.com/api
DALOOPA_API_KEY=
DALOOPA_BASE_URL=https://api.daloopa.com

# ---- Chronograph (portfolio monitoring, private equity) -----------------------
# API: Chronograph API, API key/token.
# Docs: https://www.chronograph.pe/ (acceso vía tu account manager de Chronograph)
CHRONOGRAPH_API_KEY=
CHRONOGRAPH_BASE_URL=https://api.chronograph.pe

# ---- Egnyte (almacenamiento documental) ---------------------------------------
# API: Egnyte Public API, OAuth2 token + dominio de la cuenta.
# Docs: https://developers.egnyte.com/docs
EGNYTE_DOMAIN=
EGNYTE_API_TOKEN=
